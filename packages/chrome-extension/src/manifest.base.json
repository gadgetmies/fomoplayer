{
  "manifest_version": 3,
  "name": "Fomo Player",
  "action": {
    "default_title": "Sync to Fomo Player",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "tabs", "storage", "scripting", "identity"],
  "host_permissions": [
    "https://*.beatport.com/*",
    "https://*.bandcamp.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://*.beatport.com/*"],
      "js": ["content-beatport.bundle.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.bandcamp.com/*"],
      "js": ["content-bandcamp.bundle.js"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["auth-callback.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
